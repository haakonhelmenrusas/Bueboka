# Public runtime variables (available in app code)
# Backend API base URL (must include /api)
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Optional: Microsoft Clarity project key (leave empty to disable Clarity)
EXPO_PUBLIC_CLARITY_KEY=

# Build/submit variables used by tooling (not read by app runtime)
# Path to Google Play service account JSON used by EAS submit android
GOOGLE_SERVICE_ACCOUNT_PATH=/absolute/path/to/google-service-account.json

# Optional: auth token for uploading source maps to Sentry during builds
SENTRY_AUTH_TOKEN=

