{
  "expo": {
    "scheme": "bueboka",
    "owner": "rusas_design",
    "web": {
      "bundler": "metro"
    },
    "name": "Bueboka",
    "slug": "bueboka",
    "version": "1.6.5",
    "icon": "./assets/images/icon.png",
    "extra": {
      "eas": {
        "projectId": "a740b024-fdf9-420d-9998-a6ae076ebc43"
      }
    },
    "android": {
      "package": "com.aaronshade.bueboka",
      "splash": {
        "image": "./assets/images/splash.png",
        "resizeMode": "cover",
        "backgroundColor": "#29B6F6"
      }
    },
    "androidStatusBar": {
      "barStyle": "light-content"
    },
    "ios": {
      "bundleIdentifier": "com.aaronshade.bueboka",
      "splash": {
        "image": "./assets/images/splash.png",
        "resizeMode": "cover",
        "backgroundColor": "#29B6F6"
      },
      "infoPlist": {
        "CFBundleShortVersionString": "1.6.5",
        "CFBundleIconName": "./assets/images/ipad.png",
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Bueboka trenger tilgang til bilder for at du skal kunne velge profilbilde.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["bueboka"]
          }
        ]
      }
    },
    "runtimeVersion": "1.0.1",
    "updates": {
      "url": "https://u.expo.dev/a740b024-fdf9-420d-9998-a6ae076ebc43"
    },
    "plugins": [
      "./plugins/withSoftInputMode",
      "expo-font",
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "34.0.0"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "backgroundColor": "#29B6F6",
          "resizeMode": "cover"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "bueboka",
          "organization": "haakon-rusas"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Bueboka trenger tilgang til bilder for at du skal kunne velge profilbilde."
        }
      ],
      "expo-image",
      "expo-web-browser",
      "expo-secure-store"
    ]
  }
}
